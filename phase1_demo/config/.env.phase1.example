# --- AEGIS Change Guard Server Configuration ---

# SCM credentials
AEGIS_GITHUB_TOKEN=ghp_replace_me
AEGIS_GITLAB_TOKEN=glpat_replace_me

# Webhook signature verification
AEGIS_GITHUB_WEBHOOK_SECRET=replace_with_hmac_secret
AEGIS_GITLAB_WEBHOOK_TOKEN=replace_with_random_token

# Server binding
AEGIS_SERVER_HOST=0.0.0.0
AEGIS_SERVER_PORT=8787
AEGIS_LOG_LEVEL=info

# Workspace for auto-cloned repos
AEGIS_WORKSPACE_DIR=/tmp/aegis-repos

# Output directory for review artifacts
AEGIS_OUTPUT_DIR=aegis-output/change-guard

# Analysis toggles
AEGIS_RUN_SEMGREP=true
AEGIS_MAX_DIFF_BYTES=400000
AEGIS_MAX_FILES=200
AEGIS_MAX_ADDED_LINES=12000

# Optional MCP adapter files
AEGIS_KNOWN_SECRET_HASHES_FILE=test_files/phase1_demo/config/known_secret_hashes.example.txt
AEGIS_POLICY_RULES_FILE=test_files/phase1_demo/config/policy_rules.example.json
